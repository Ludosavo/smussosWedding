# ====================================
# Environment Variables for Wedding Site
# ====================================
# Copy this file to .env.local for local development
# Set these same variables in Vercel Dashboard for production

# Resend API Key
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email to receive RSVP notifications
# This is where you'll get notified when guests RSVP
RSVP_NOTIFICATION_EMAIL=old2shatterhand@gmail.com
